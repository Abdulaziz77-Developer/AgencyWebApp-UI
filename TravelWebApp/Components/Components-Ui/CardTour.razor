@code {
    [Parameter] public TravelWebApp.Models.Tour? Tour { get; set; }
    private bool isMapVisible = false;

    private async Task OpenMap()
    {
        isMapVisible = true;
        StateHasChanged();

        if (Tour != null)
        {
            await Task.Delay(400);
            await JSRuntime.InvokeVoidAsync("leafletBridge.showLocation",
                $"map-{Tour.Id}",
                Tour.StartLatitude,
                Tour.StartLongitude,
                Tour.Title);
        }
    }

    private void CloseMap() => isMapVisible = false;
}

<style>
    /* Находим вашу карточку по классу card-hover */
    .card-hover {
        transition: all 0.3s ease-in-out !important;
        /* Убедимся, что начальная тень видна */
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
    }

        /* Эффект при наведении */
        .card-hover:hover {
            /* Увеличение */
            transform: scale(1.03) !important;
            /* Глубокая тень */
            box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.175) !important;
            z-index: 10;
        }

        /* Чтобы картинка не дергалась при увеличении */
        .card-hover img {
            transition: transform 0.3s ease;
        }
</style>