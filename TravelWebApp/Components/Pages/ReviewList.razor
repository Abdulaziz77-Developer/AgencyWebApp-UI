@* @page "/reviews"
@using TravelWebApp.Models
@using TravelWebApp.Services.Interfaces
@using TravelWebApp.Components.Components_Ui
@inject IReviewService ReviewService
@inject IUserServiceCrud UserService
@inject ITourService TourService
@inject IHotelService HotelService
@inject IFlightService FlightService

<div class="min-vh-100 bg-light">
    <div class="container py-5">
        <h1 class="display-5 fw-bold mb-5">Отзывы наших клиентов</h1>

        <!-- Summary Cards -->
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <CardReview Count="@reviews.Count" Label="Всего отзывов" />
            </div>
            <div class="col-md-4">
                <div class="card border rounded-4 h-100">
                    <div class="card-body p-4 text-center">
                        <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                            <p class="fs-1 fw-bold text-primary mb-0">@(reviews.Any() ? reviews.Average(r => r.Rating).ToString("0.0") : "0.0")</p>
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning">
                                <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
                            </svg>
                        </div>
                        <p class="text-muted mb-0">Средний рейтинг</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <CardReview Count="@reviews.Count(r => r.Rating == 5)" Label="5-звездочных отзывов" />
            </div>
        </div>

        <!-- Reviews Grid -->
        <div class="row g-4">
            @if (reviews.Any())
            {
                @foreach (var review in reviews)
                {
                    <div class="col-md-6">
                        <div class="card border rounded-4 h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h5 class="card-title fw-bold mb-1">@review.UserName</h5>
                                        <p class="text-muted small mb-0">
                                            @if (review.TourId > 0)
                                            {
                                                <span>Tour ID: @review.TourId</span>
                                            }
                                            else if (review.HotelId > 0)
                                            {
                                                <span>Hotel ID: @review.HotelId</span>
                                            }
                                            else if (review.FlightId > 0)
                                            {
                                                <span>Flight ID: @review.FlightId</span>
                                            }
                                        </p>
                                    </div>
                                    <div class="d-flex text-warning">
                                        @for (int i = 0; i < 5; i++)
                                        {
                                            if (i < review.Rating)
                                            {
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
                                                </svg>
                                            }
                                            else
                                            {
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary opacity-25">
                                                    <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
                                                </svg>
                                            }
                                        }
                                    </div>
                                </div>
                                <p class="card-text text-secondary mb-3">@review.Text</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">@review.Date.ToString("dd MMM yyyy")</small>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-info text-center py-5" role="alert">
                        <h5>No reviews available yet</h5>
                        <p class="text-muted mb-0">Be the first to leave a review!</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<Review> reviews = new List<Review>();
    private Dictionary<int, string> userNames = new Dictionary<int, string>();

    protected override async Task OnInitializedAsync()
    {
        // Get all reviews from the ReviewService
        reviews = await ReviewService.GetReviewsAsync();
        Console.WriteLine($"Fetched {reviews.Count} reviews from service.");

        // Fetch username for each review
        foreach (var review in reviews)
        {
            try
            {
                var user = await UserService.GetUserByIdAsync(review.UserId);
                if (user != null)
                {
                    review.UserName = user.FullName ?? $"User {review.UserId}";
                }
                else
                {
                    review.UserName = $"User {review.UserId}";
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error fetching user {review.UserId}: {ex.Message}");
                review.UserName = $"User {review.UserId}";
            }
        }

        // Fetch username for each review
        foreach (var review in reviews)
        {
            try
            {
                var user = await UserService.GetUserByIdAsync(review.UserId);
                if (user != null)
                {
                    userNames[review.UserId] = user.FullName ?? $"User {review.UserId}";
                    review.UserName = user.FullName ?? $"User {review.UserId}";
                }
                else
                {
                    review.UserName = $"User {review.UserId}";
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error fetching user {review.UserId}: {ex.Message}");
                review.UserName = $"User {review.UserId}";
            }
        }
    }
} *@
@page "/reviews"
@using System.Text.Json.Serialization
@using TravelWebApp.Models
@using TravelWebApp.Services.Interfaces
@using TravelWebApp.Components.Components_Ui
@inject IReviewService ReviewService
@inject IUserServiceCrud UserService

<div class="min-vh-100 bg-light pb-5">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold text-dark">Отзывы клиентов</h1>
            <p class="text-muted fs-5">Мы ценим каждое мнение о наших путешествиях</p>
        </div>

        @if (reviews == null)
        {
            <div class="d-flex flex-column align-items-center justify-content-center py-5">
                <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
                <p class="text-secondary fw-medium">Загружаем честные отзывы...</p>
            </div>
        }
        else
        {
            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 bg-primary text-white">
                        <div class="card-body p-4 text-center">
                            <h3 class="display-5 fw-bold mb-0">@reviews.Count</h3>
                            <p class="mb-0 opacity-75">Всего мнений</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                        <div class="card-body p-4 text-center">
                            <div class="d-flex align-items-center justify-content-center gap-2 mb-1">
                                <h3 class="display-5 fw-bold text-dark mb-0">5.0</h3>
                                <i class="bi bi-star-fill text-warning fs-3"></i>
                            </div>
                            <p class="text-muted mb-0">Высшая оценка</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 bg-dark text-white">
                        <div class="card-body p-4 text-center">
                            <h3 class="display-5 fw-bold mb-0">100%</h3>
                            <p class="mb-0 opacity-75">Довольных гостей</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                @if (reviews.Any())
                {
                    @foreach (var review in reviews)
                    {
                        <div class="col-lg-6">
                            <div class="card border-0 shadow-sm rounded-4 h-100 review-card">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between mb-3">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-circle bg-soft-primary text-primary fw-bold">
                                                @(string.IsNullOrEmpty(review.UserName) ? "?" : review.UserName[0].ToString().ToUpper())
                                            </div>
                                            <div>
                                                <h6 class="fw-bold mb-0">@review.UserName</h6>
                                                <small class="text-muted">@review.Date?.ToString("dd MMMM yyyy")</small>
                                            </div>
                                        </div>
                                        <div class="badge-category">
                                            @if (review.TourId > 0) { <span class="badge bg-info-subtle text-info rounded-pill">Тур #@review.TourId</span> }
                                            else if (review.HotelId > 0) { <span class="badge bg-success-subtle text-success rounded-pill">Отель #@review.HotelId</span> }
                                            else { <span class="badge bg-secondary-subtle text-secondary rounded-pill">Общий</span> }
                                        </div>
                                    </div>
                                    
                                    <p class="card-text text-dark-emphasis mb-0 italic-text">
                                        "@review.Text"
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <div class="card border-dashed p-5 rounded-4 bg-transparent">
                            <i class="bi bi-chat-left-dots display-1 text-muted mb-3"></i>
                            <h4 class="text-secondary">Отзывов пока нет</h4>
                            <p class="text-muted">Станьте первым, кто поделится впечатлениями!</p>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .bg-soft-primary { background-color: #e7f1ff; }
    .avatar-circle {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-size: 1.2rem;
    }
    .review-card {
        transition: transform 0.2s ease, shadow 0.2s ease;
    }
    .review-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
    }
    .italic-text { font-style: italic; line-height: 1.6; }
    .border-dashed { border: 2px dashed #dee2e6; }
</style>

@code {
    private List<AdminReviewModel>? reviews;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var rawData = await ReviewService.GetReviewsAsync();

            if (rawData != null)
            {
                reviews = rawData.Select(r => new AdminReviewModel
                {
                    Id = r.Id,
                    UserId = r.UserId,
                    Text = r.Text,
                    TourId = r.TourId,
                    HotelId = r.HotelId,
                    FlightId = r.FlightId,
                    Date = r.Date 
                }).ToList();
                
                // Загружаем имена пользователей параллельно для скорости
                var tasks = reviews.Select(async review =>
                {
                    if (string.IsNullOrWhiteSpace(review.UserName))
                    {
                        var user = await UserService.GetUserByIdAsync(review.UserId);
                        review.UserName = user?.FullName ?? $"Клиент #{review.UserId}";
                    }
                });

                await Task.WhenAll(tasks);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка в компоненте отзывов: {ex.Message}");
            reviews = new List<AdminReviewModel>();
        }
    }

    public class AdminReviewModel
    {
        public int Id { get; set; }
        public int UserId { get; set; }
        public int? TourId { get; set; }
        public int? FlightId { get; set; }
        public int? HotelId { get; set; }
        public string? Text { get; set; }
        
        // Ключевой момент: проверь как называется поле в JSON API
        [JsonPropertyName("createdAt")] 
        public DateTime? Date { get; set; }
        
        public string? UserName { get; set; }
    }
}