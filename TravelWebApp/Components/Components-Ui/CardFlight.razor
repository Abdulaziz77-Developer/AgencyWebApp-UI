@* @namespace TravelWebApp.Components.Components_Ui

<style>
    .card-hover-effect {
        transition: box-shadow 0.3s ease, transform 0.3s ease;
        cursor: pointer;
    }
    .card-hover-effect:hover {
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
    }
</style>

<div class="card h-100 border rounded-4 overflow-hidden shadow-sm card-hover-effect">
    <div class="card-body p-4">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <span class="badge border text-dark bg-transparent fw-medium">@Airline</span>
            <span class="badge bg-success">@Status</span>
        </div>
        
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <div class="fs-4 fw-bold">@Origin</div>
                <div class="small text-muted">@DepartureTime</div>
            </div>
            
            <div class="flex-grow-1 px-4">
                <div class="position-relative border-top border-2 border-secondary" style="border-style: dashed !important; opacity: 0.3;">
                    <div class="position-absolute top-0 start-50 translate-middle bg-white px-2 small text-muted">
                        @Duration
                    </div>
                </div>
            </div>
            
            <div class="text-end">
                <div class="fs-4 fw-bold">@Destination</div>
                <div class="small text-muted">@ArrivalTime</div>
            </div>
        </div>
        
        <div class="d-flex align-items-center justify-content-between pt-3 border-top">
            <div class="small text-muted">@ClassType</div>
            <div>
                <span class="fs-4 fw-bold text-primary">$@Price</span>
            </div>
        </div>
    </div>
    
    <div class="card-footer bg-white border-top-0 p-4 pt-0">
        <button class="btn btn-primary w-100">Select Flight</button>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    [Parameter] public string Airline { get; set; } = "SkyWings Airlines";
    [Parameter] public string Status { get; set; } = "On Time";
    [Parameter] public string Origin { get; set; } = "New York";
    [Parameter] public string DepartureTime { get; set; } = "18:30";
    [Parameter] public string Destination { get; set; } = "London";
    [Parameter] public string ArrivalTime { get; set; } = "06:45";
    [Parameter] public string Duration { get; set; } = "7h 15m";
    [Parameter] public string ClassType { get; set; } = "Economy";
    [Parameter] public decimal Price { get; set; } = 650;
} *@
