@page "/admindashboard"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using AgencyWebApp.Client.Infrastructure.Api.Dtos.Bookings
@using AgencyWebApp.Client.Infrastructure.Api.Dtos.Flights
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using TravelWebApp.Shared.Components
@using System.Linq
@using Microsoft.AspNetCore.Components.Forms
@using TravelWebApp.Infrastrcuture.api.Services.Interfaces
@using TravelWebApp.Infrastrcuture.api.dtos.Hotels
@using TravelWebApp.Infrastrcuture.api.dtos.Reviews
@using TravelWebApp.Infrastrcuture.api.dtos.Tours
@using TravelWebApp.Infrastrcuture.api.dtos.Users
@using TravelWebApp.Services
@using System.ComponentModel.DataAnnotations
@using TravelWebApp.Shared.Layout
@using Microsoft.AspNetCore.Hosting
@using System.IO
@using Microsoft.JSInterop
<Navbar />

<div class="min-vh-100 bg-light">
    <div class="container py-5">
        <!-- Header -->
        <div class="d-flex align-items-center gap-3 mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
                <circle cx="12" cy="12" r="3"></circle>
            </svg>
            <h1 class="display-5 fw-bold mb-0">Панель администратора</h1>
        </div>

        <!-- Summary Cards -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-5 g-4 mb-5">
            <div class="col">
                <div class="card border rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                                <path d="m16.24 7.76-1.804 5.411a2 2 0 0 1-1.265 1.265L7.76 16.24l1.804-5.411a2 2 0 0 1 1.265-1.265z"></path>
                                <circle cx="12" cy="12" r="10"></circle>
                            </svg>
                            <div>
                                <p class="small text-muted mb-0">Туры</p>
                                <p class="fs-4 fw-bold mb-0">@tours.Count</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success">
                                <path d="M10 22v-6.57"></path><path d="M12 11h.01"></path><path d="M12 7h.01"></path><path d="M14 15.43V22"></path><path d="M15 16a5 5 0 0 0-6 0"></path><path d="M16 11h.01"></path><path d="M16 7h.01"></path><path d="M8 11h.01"></path><path d="M8 7h.01"></path><rect x="4" y="2" width="16" height="20" rx="2"></rect>
                            </svg>
                            <div>
                                <p class="small text-muted mb-0">Отели</p>
                                <p class="fs-4 fw-bold mb-0">@adminHotels.Count</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-600" style="color: #9333ea;">
                                <path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"></path>
                            </svg>
                            <div>
                                <p class="small text-muted mb-0">Авиарейсы</p>
                                <p class="fs-4 fw-bold mb-0">@adminFlights.Count</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning">
                                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                            <div>
                                <p class="small text-muted mb-0">Бронирования</p>
                                <p class="fs-4 fw-bold mb-0">@adminBookings.Count</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-danger">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                            </svg>
                            <div>
                                <p class="small text-muted mb-0">Отзывы</p>
                                <p class="fs-4 fw-bold mb-0">@adminReviews.Count</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-pills nav-fill gap-2 p-1 bg-white rounded-4 border mb-4">
            <li class="nav-item">
                <button class="nav-link rounded-4 @(activeTab == Tab.Tours ? "active" : "")" @onclick="@(() => SetActiveTab(Tab.Tours))" type="button">Туры</button>
            </li>
            <li class="nav-item">
                <button class="nav-link rounded-4 @(activeTab == Tab.Hotels ? "active" : "")" @onclick="@(() => SetActiveTab(Tab.Hotels))" type="button">Отели</button>
            </li>
            <li class="nav-item">
                <button class="nav-link rounded-4 @(activeTab == Tab.Flights ? "active" : "")" @onclick="@(() => SetActiveTab(Tab.Flights))" type="button">Авиарейсы</button>
            </li>
            <li class="nav-item">
                <button class="nav-link rounded-4 @(activeTab == Tab.Bookings ? "active" : "")" @onclick="@(() => SetActiveTab(Tab.Bookings))" type="button">Бронирования</button>
            </li>
            <li class="nav-item">
                <button class="nav-link rounded-4 @(activeTab == Tab.Reviews ? "active" : "")" @onclick="@(() => SetActiveTab(Tab.Reviews))" type="button">Отзывы</button>
            </li>
        </ul>

        <!-- Tab Content -->
        <div>
            @if (activeTab == Tab.Tours)
            {
                <div>
                <div class="card border rounded-4">
                    <div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 fw-bold">Управление турами</h4>
                        <button class="btn btn-primary d-flex align-items-center gap-2" @onclick="OpenAddTourModal">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12h14"></path><path d="M12 5v14"></path>
                            </svg>
                           Создать тур
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="px-4 py-3">Название</th>
                                        <th class="px-4 py-3">Регион</th>
                                        <th class="px-4 py-3">Цена</th>
                                        <th class="px-4 py-3">Продолжительность</th>
                                        @* <th class="px-4 py-3">Рейтинг</th>
                                        <th class="px-4 py-3">Статус</th> *@
                                        <th class="px-4 py-3">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var tour in tours) {
                                        <tr>
                                            <td class="px-4 py-3 fw-medium">@tour.Title</td>
                                            <td class="px-4 py-3">@tour.Region</td>
                                            <td class="px-4 py-3">@tour.Price.ToString("C0")</td>
                                            <td class="px-4 py-3">@tour.Duration</td>
                                            @* <td class="px-4 py-3">@tour.Rating</td>
                                            <td class="px-4 py-3">
                                                <span class="badge @(tour.Status ? "bg-success" : "bg-danger") bg-opacity-10 text-@(tour.Status ? "success" : "danger") rounded-pill px-3">
                                                    @(tour.IsAvailable ? "Доступен" : "Недоступен")
                                                </span>
                                            </td> *@
                                            <td class="px-4 py-3">
                                                <div class="d-flex gap-2">
                                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => OpenEditTourModal(tour)">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square-pen"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"></path></svg>
                                                    </button>
                                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteTour(tour.Id)">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash2"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path><line x1="10" x2="10" y1="11" y2="17"></line><line x1="14" x2="14" y1="11" y2="17"></line></svg>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @if (showTourModal)
                {
                    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">@(isNewTour ? "Добавить тур" : "Редактировать тур")</h5>
                                    <button type="button" class="btn-close" @onclick="CloseTourModal"></button>
                                </div>
                                <div class="modal-body">
                                    <EditForm Model="@editingTour">
                                        <DataAnnotationsValidator />
                                        <div class="mb-3">
                                            <label class="form-label">Название</label>
                                            <InputText @bind-Value="editingTour.Title" class="form-control" />
                                            <ValidationMessage For="@(() => editingTour.Title)" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Описание</label>
                                            <InputTextArea @bind-Value="editingTour.Description" class="form-control" />
                                            <ValidationMessage For="@(() => editingTour.Description)" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Цена</label>
                                            <InputNumber @bind-Value="editingTour.Price" class="form-control" />
                                            <ValidationMessage For="@(() => editingTour.Price)" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Регион</label>
                                            <InputText @bind-Value="editingTour.Region" class="form-control" />
                                            <ValidationMessage For="@(() => editingTour.Region)" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Фотография</label>
                                            <InputFile OnChange="HandleTourImageUpload" class="form-control" accept=".jpg,.jpeg,.png" />
                                            @if (!string.IsNullOrEmpty(editingTour.PhotoUrl))
                                            {
                                                <div class="mt-2">
                                                    @if (editingTour.PhotoUrl.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <video src="@editingTour.PhotoUrl" controls class="img-thumbnail" style="max-height: 100px"></video>
                                                    }
                                                    else
                                                    {
                                                        <img src="@editingTour.PhotoUrl" alt="Preview" class="img-thumbnail" style="max-height: 100px" />
                                                    }
                                                </div>
                                            }
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                    <label class="form-label">Широта</label>
                                                <InputNumber @bind-Value="editingTour.StartLatitude" class="form-control" />
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                    <label class="form-label">Долгота</label>
                                                <InputNumber @bind-Value="editingTour.StartLongitude" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Продолжительность</label>
                                            <InputNumber @bind-Value="editingTour.Duration" class="form-control" />
                                            <ValidationMessage For="@(() => editingTour.Duration)" />
                                        </div>
                                        @* <div class="mb-3">
                                            <label class="form-label">Рейтинг</label>
                                            <InputNumber @bind-Value="editingTour.Rating" class="form-control" step="0.1" />
                                            <ValidationMessage For="@(() => editingTour.Rating)" />
                                        </div>
                                        <div class="mb-3 form-check">
                                            <InputCheckbox @bind-Value="editingTour.Status" class="form-check-input" />
                                            <label class="form-check-label">Доступен</label>
                                        </div> *@
                                        <div class="modal-footer px-0 pb-0">
                                                <button type="button" class="btn btn-secondary" @onclick="CloseTourModal">Отмена</button>
                                            <button type="submit" class="btn btn-primary" @onclick="SaveTour">Сохранить</button>
                                        </div>
                                    </EditForm>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            }

            @if (activeTab == Tab.Hotels)
            {
                <div>
                <div class="card border rounded-4">
                    <div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 fw-bold">Управление отелями</h4>
                        <button class="btn btn-primary d-flex align-items-center gap-2" @onclick="OpenAddHotelModal">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>
                            Добавить отель
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="px-4 py-3">Название</th>
                                            <th class="px-4 py-3">Местоположение</th>
                                        <th class="px-4 py-3">Цена</th>
                                        @* <th class="px-4 py-3">Рейтинг</th>
                                        <th class="px-4 py-3">Статус</th> *@
                                        <th class="px-4 py-3">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var hotel in adminHotels) {
                                        <tr>
                                            <td class="px-4 py-3 fw-medium">@hotel.Name</td>
                                            <td class="px-4 py-3">@hotel.City</td>
                                            <td class="px-4 py-3">@hotel.Price.ToString("C0")</td>
                                            @* <td class="px-4 py-3">@hotel.Rating</td>
                                            <td class="px-4 py-3">
                                                <span class="badge @(hotel.IsAvailable ? "bg-success" : "bg-danger") bg-opacity-10 text-@(hotel.IsAvailable ? "success" : "danger") rounded-pill px-3">
                                                    @(hotel.IsAvailable ? "Доступен" : "Недоступен")
                                                </span>
                                            </td> *@
                                            <td class="px-4 py-3">
                                                <div class="d-flex gap-2">
                                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => OpenEditHotelModal(hotel)"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square-pen"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"></path></svg></button>
                                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteHotel(hotel.Id)"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash2"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path><line x1="10" x2="10" y1="11" y2="17"></line><line x1="14" x2="14" y1="11" y2="17"></line></svg></button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            @if (showHotelModal)
            {
                <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">@(isNewHotel ? "Добавить отель" : "Изменить отель")</h5>
                                <button type="button" class="btn-close" @onclick="CloseHotelModal"></button>
                            </div>
                            <div class="modal-body">
                                <EditForm Model="@editingHotel" OnValidSubmit="SaveHotel">
                                    <DataAnnotationsValidator />
                                    <div class="mb-3">
                                        <label class="form-label">Название</label>
                                        <InputText @bind-Value="editingHotel.Name" class="form-control" />
                                        <ValidationMessage For="@(() => editingHotel.Name)" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Местоположение</label>
                                        <InputText @bind-Value="editingHotel.City" class="form-control" />
                                        <ValidationMessage For="@(() => editingHotel.City)" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Цена</label>
                                        <InputNumber @bind-Value="editingHotel.Price" class="form-control" />
                                        <ValidationMessage For="@(() => editingHotel.Price)" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Рейтинг</label>
                                        <InputNumber @bind-Value="editingHotel.Rating" class="form-control" step="0.1" />
                                        <ValidationMessage For="@(() => editingHotel.Rating)" />
                                    </div>
                                    <div class="mb-3 form-check">
                                        <InputCheckbox @bind-Value="editingHotel.Status" class="form-check-input" />
                                            <label class="form-check-label">Доступен</label>
                                    </div>
                                    <div class="modal-footer px-0 pb-0">
                                        <button type="button" class="btn btn-secondary" @onclick="CloseHotelModal">Отмена</button>
                                        <button type="submit" class="btn btn-primary">Сохранить</button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                </div>
            }
            }

            @if (activeTab == Tab.Flights)
            {
                <div>
                <div class="card border rounded-4">
                    <div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center">
                            <h4 class="mb-0 fw-bold">Управление рейсами</h4>
                        <button class="btn btn-primary d-flex align-items-center gap-2" @onclick="OpenAddFlightModal">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>
                            Добавить рейс
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="bg-light">
                                    <tr>
                                            <th class="px-4 py-3">Авиакомпания</th>
                                        <th class="px-4 py-3">Маршрут</th>
                                        <th class="px-4 py-3">Дата</th>
                                        <th class="px-4 py-3">Цена</th>
                                        @* <th class="px-4 py-3">Статус</th> *@
                                        <th class="px-4 py-3">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var flight in adminFlights) {
                                        <tr>
                                            <td class="px-4 py-3 fw-medium">@flight.airPlaneName</td>
                                            <td class="px-4 py-3">@flight.fromCity => @flight.toCity</td>
                                            <td class="px-4 py-3">@flight.departureTime => @flight.arrivalTime</td>
                                            <td class="px-4 py-3">@flight.Price.ToString("C0")</td>
                                            <td class="px-4 py-3">
                                                <div class="d-flex gap-2">
                                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => OpenEditFlightModal(flight)"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square-pen"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"></path></svg></button>
                                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteFlight(flight.id)"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash2"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path><line x1="10" x2="10" y1="11" y2="17"></line><line x1="14" x2="14" y1="11" y2="17"></line></svg></button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @if (showFlightModal)
                {
                    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">@(isNewFlight ? "Добавить рейс" : "Редактировать рейс")</h5>
                                    <button type="button" class="btn-close" @onclick="CloseFlightModal"></button>
                                </div>
                                <div class="modal-body">
                                    <EditForm Model="@editingFlight" OnValidSubmit="SaveFlight">
                                        <DataAnnotationsValidator />
                                        <div class="mb-3">
                                            <label class="form-label">Название самолета</label>
                                            <InputText @bind-Value="editingFlight.airPlaneName" class="form-control" />
                                        </div>
                                        <div class="mb-3">
                                                <label class="form-label">Номер рейса</label>
                                            <InputNumber @bind-Value="editingFlight.flightNumber" class="form-control" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Город отправления</label>
                                            <InputText @bind-Value="editingFlight.fromCity" class="form-control" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Город назначения</label>
                                            <InputText @bind-Value="editingFlight.toCity" class="form-control" />
                                        </div>
                                        <div class="mb-3">
                                                <label class="form-label">Время отправления</label>
                                            <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="editingFlight.departureTime" class="form-control" />
                                        </div>
                                        <div class="mb-3">
                                                <label class="form-label">Время прибытия</label>
                                            <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="editingFlight.arrivalTime" class="form-control" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Цена</label>
                                            <InputNumber @bind-Value="editingFlight.Price" class="form-control" />
                                        </div>
                                        <div class="modal-footer px-0 pb-0">
                                            <button type="button" class="btn btn-secondary" @onclick="CloseFlightModal">Отмена</button>
                                            <button type="submit" class="btn btn-primary">Сохранить</button>
                                        </div>
                                    </EditForm>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            }

            @if (activeTab == Tab.Bookings)
            {
                <div>
                <div class="card border rounded-4">
                    <div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center">
                            <h4 class="mb-0 fw-bold">Управление бронированиями</h4>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="px-4 py-3">Пользователь</th>
                                        <th class="px-4 py-3">Объект</th>
                                        <th class="px-4 py-3">Дата</th>
                                        <th class="px-4 py-3">Цена</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var booking in adminBookings) {
                                        <tr>
                                            <td class="px-4 py-3 fw-medium">@booking.User</td>
                                            <td class="px-4 py-3">@booking.Item</td>
                                            <td class="px-4 py-3">@booking.Date</td>
                                            <td class="px-4 py-3">@booking.Price</td>
                                                <td class="px-4 py-3">
                                                    <div class="d-flex align-items-center gap-2">
                                                        @if (booking.Status)
                                                        {
                                                            <span class="badge bg-success">Подтверждено</span>
                                                        }
                                                        else
                                                        {
                                                            <button class="btn btn-sm btn-primary" @onclick="() => ConfirmBooking(booking.Id)">Подтвердить</button>
                                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteBooking(booking.Id)">Удалить</button>
                                                        }
                                                    </div>
                                                </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            }
            @if (activeTab == Tab.Reviews)
            {
                <div>
                <div class="card border rounded-4">
                    <div class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center">
                            <h4 class="mb-0 fw-bold">Управление отзывами</h4>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="px-4 py-3">Пользователь</th>
                                        <th class="px-4 py-3">Объект</th>
                                        <th class="px-4 py-3">Комментарий</th>
                                        <th class="px-4 py-3">Дата</th>
                                        <th class="px-4 py-3">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var review in reviews) {
                                        <tr>
                                            <td class="px-4 py-3 fw-medium">@review.UserName</td>
                                            <td class="px-4 py-3">@review.Item</td>
                                            <td class="px-4 py-3 text-truncate" style="max-width: 200px;">@review.Text</td>
                                            <td class="px-4 py-3">@review.Date</td>
                                            <td class="px-4 py-3">
                                                <div class="d-flex gap-2">
                                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteReview(review.Id)"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash2"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path><line x1="10" x2="10" y1="11" y2="17"></line><line x1="14" x2="14" y1="11" y2="17"></line></svg></button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>

                            </table>
                        </div>
                    </div>
                </div>
            </div>
            }
        </div>
    </div>
</div>

