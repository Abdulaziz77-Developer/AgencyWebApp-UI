@* @page "/tours"
@using TravelWebApp.Shared.Components

<Navbar />

<div class="bg-light min-vh-100">
    <!-- Page Header -->
    <div class="bg-white border-bottom">
        <div class="container py-5">
            <h1 class="display-5 fw-bold text-dark mb-2">Explore Tours</h1>
            <p class="text-muted mb-0">Discover amazing destinations around the world</p>
        </div>
    </div>

    <div class="container py-5">
        <div class="row g-4">
            <!-- Sidebar Filters -->
            <div class="col-lg-3">
                <div class="card border rounded-4 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-funnel">
                                <path d="M10 20a1 1 0 0 0 .553.895l2 1A1 1 0 0 0 14 21v-7a2 2 0 0 1 .517-1.341L21.74 4.67A1 1 0 0 0 21 3H3a1 1 0 0 0-.742 1.67l7.225 7.989A2 2 0 0 1 10 14z"></path>
                            </svg>
                            <h5 class="fw-semibold mb-0">Filters</h5>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Search</label>
                            <input type="text" class="form-control" placeholder="Search tours...">
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Price Range</label>
                            <div class="d-flex gap-2">
                                <input type="number" class="form-control" placeholder="Min">
                                <input type="number" class="form-control" placeholder="Max">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Category</label>
                            <select class="form-select">
                                <option selected>All Categories</option>
                                <option>Beach</option>
                                <option>Mountain</option>
                                <option>Cultural</option>
                                <option>City</option>
                                <option>Adventure</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Duration</label>
                            <select class="form-select">
                                <option selected>Any Duration</option>
                                <option>1-3 Days</option>
                                <option>4-7 Days</option>
                                <option>8-14 Days</option>
                                <option>15+ Days</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Rating</label>
                            <div class="d-flex flex-col gap-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="rating4">
                                    <label class="form-check-label d-flex align-items-center" for="rating4">
                                        <div class="d-flex text-warning">
                                            @for(int i=0; i<4; i++) { <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg> }
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
                                        </div>
                                        <span class="small ms-1">& up</span>
                                    </label>
                                </div>
                                <div class="form-check mt-2">
                                    <input class="form-check-input" type="checkbox" id="rating3">
                                    <label class="form-check-label d-flex align-items-center" for="rating3">
                                        <div class="d-flex text-warning">
                                            @for(int i=0; i<3; i++) { <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg> }
                                            @for(int i=0; i<2; i++) { <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg> }
                                        </div>
                                        <span class="small ms-1">& up</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <button class="btn btn-primary w-100">Apply Filters</button>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-9">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="text-muted">Showing <span class="fw-semibold text-dark">@tours.Count</span> tours</div>
                    <div style="width: 200px;">
                        <select class="form-select form-select-sm">
                            <option selected>Featured</option>
                            <option>Price: Low to High</option>
                            <option>Price: High to Low</option>
                            <option>Rating</option>
                        </select>
                    </div>
                </div>

                <div class="row g-4">
                    @foreach (var tour in tours)
                    {
                        <div class="col-md-6">
                            <div class="card h-100 border rounded-4 overflow-hidden shadow-sm" style="cursor: pointer; transition: box-shadow 0.3s ease;" onmouseover="this.style.boxShadow='0 1rem 3rem rgba(0,0,0,.175)'" onmouseout="this.style.boxShadow='0 .125rem .25rem rgba(0,0,0,.075)'">
                                <div class="position-relative" style="height: 12rem;">
                                    <img src="@tour.ImageUrl" alt="@tour.Title" class="w-100 h-100 object-fit-cover">
                                    @if (tour.IsFeatured)
                                    {
                                        <span class="badge bg-primary position-absolute top-0 end-0 m-3">Featured</span>
                                    }
                                    <span class="badge bg-white text-dark position-absolute top-0 start-0 m-3">@tour.Category</span>
                                </div>
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center gap-2 small text-muted mb-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin">
                                            <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
                                            <circle cx="12" cy="10" r="3"></circle>
                                        </svg>
                                        @tour.Location
                                    </div>
                                    <h5 class="card-title fw-semibold mb-2">@tour.Title</h5>
                                    <p class="card-text small text-muted mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @tour.Description
                                    </p>
                                    <div class="d-flex align-items-center gap-3 mb-3">
                                        <div class="d-flex align-items-center gap-1">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning">
                                                <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
                                            </svg>
                                            <span class="small fw-medium">@tour.Rating</span>
                                        </div>
                                        <div class="d-flex align-items-center gap-1 small text-muted">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar">
                                                <path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path>
                                            </svg>
                                            @tour.Duration
                                        </div>
                                        <div class="d-flex align-items-center gap-1 small text-muted">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users">
                                                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><path d="M16 3.128a4 4 0 0 1 0 7.744"></path><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><circle cx="9" cy="7" r="4"></circle>
                                            </svg>
                                            @tour.GroupSize
                                        </div>
                                    </div>
                                    <div class="small text-muted">Starting: @tour.StartDate</div>
                                </div>
                                <div class="card-footer bg-white border-top-0 p-3 pt-0 d-flex align-items-center justify-content-between">
                                    <div>
                                        <span class="fs-4 fw-bold text-primary">$@tour.Price</span>
                                        <span class="small text-muted"> /person</span>
                                    </div>
                                    <button class="btn btn-primary btn-sm px-3">View Details</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="d-flex justify-content-center gap-2 mt-5">
                    <button class="btn btn-outline-secondary btn-sm" disabled>Previous</button>
                    <button class="btn btn-primary btn-sm">1</button>
                    <button class="btn btn-outline-secondary btn-sm">2</button>
                    <button class="btn btn-outline-secondary btn-sm">3</button>
                    <button class="btn btn-outline-secondary btn-sm">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
