@using TravelWebApp.Infrastrcuture.api.dtos.Tours
@inject IJSRuntime JSRuntime

<div class="card h-100 border rounded-4 overflow-hidden shadow-sm card-hover">
    <div class="position-relative" style="height: 200px;">
        <img src="@Tour?.PhotoUrl" class="w-100 h-100 object-fit-cover" alt="@Tour?.Title">

        @if (true)
        {
            <span class="position-absolute top-0 end-0 badge bg-primary m-3 px-2 py-1 rounded-2">Рекомендуем</span>
        }

        @* Кнопка геолокации на фото *@
        <button @onclick="OpenMap" class="position-absolute bottom-0 end-0 btn btn-white bg-white m-3 shadow-sm rounded-circle p-2 map-trigger-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d6efd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3" /></svg>
        </button>
    </div>

    <div class="card-body p-3">
        <div class="d-flex align-items-center gap-1 text-muted small mb-2">
            @* Иконка, открывающая карту *@
            <svg @onclick="OpenMap" style="cursor:pointer" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" /><circle cx="12" cy="10" r="3" /></svg>
            <span @onclick="OpenMap" style="cursor:pointer">@Tour?.Region</span>
        </div>

        <h5 class="card-title fw-bold mb-2">@Tour?.Title</h5>
        <p class="card-text text-muted small mb-3">@Tour?.Description</p>
    </div>

    @* ДОБАВЛЕНО: Футер с ценой и кнопкой подробностей *@
    <div class="card-footer bg-white border-0 pt-0 pb-3 px-3 d-flex align-items-center justify-content-between">
        <div>
            <span class="fs-5 fw-bold text-primary">$@Tour?.Price</span>
            <span class="text-muted small"> /человек</span>
        </div>
        <a href="/tour-details/@Tour?.Id" class="btn btn-primary btn-sm rounded-2 px-3">Подробнее</a>
    </div>
</div>

@* Компактное модальное окно (остается без изменений) *@
@if (isMapVisible)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 9999;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm" style="max-width: 400px;">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header py-2">
                    <h6 class="modal-title fw-bold">Локация: @Tour?.Region</h6>
                    <button type="button" class="btn-close" @onclick="CloseMap"></button>
                </div>
                <div class="modal-body p-0">
                    <div id="map-@Tour?.Id" style="height: 300px; width: 100%; background: #eee;"></div>
                </div>
                <div class="modal-footer py-1">
                    <button class="btn btn-sm btn-secondary" @onclick="CloseMap">Закрыть</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public TourDto? Tour { get; set; }
    private bool isMapVisible = false;

    private async Task OpenMap()
    {
        isMapVisible = true;
        StateHasChanged();

        if (Tour != null)
        {
            await Task.Delay(400);
            await JSRuntime.InvokeVoidAsync("leafletBridge.showLocation",
                $"map-{Tour.Id}",
                Tour.StartLatitude,
                Tour.StartLongitude,
                Tour.Title);
        }
    }

    private void CloseMap() => isMapVisible = false;
}

<style>
    /* Находим вашу карточку по классу card-hover */
    .card-hover {
        transition: all 0.3s ease-in-out !important;
        /* Убедимся, что начальная тень видна */
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
    }

        /* Эффект при наведении */
        .card-hover:hover {
            /* Увеличение */
            transform: scale(1.03) !important;
            /* Глубокая тень */
            box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.175) !important;
            z-index: 10;
        }

        /* Чтобы картинка не дергалась при увеличении */
        .card-hover img {
            transition: transform 0.3s ease;
        }
</style>