@code {
    [Parameter] public TravelWebApp.Models.Tour? Tour { get; set; }
    
    private bool isMapVisible = false;

    private async Task ToggleMap()
    {
        isMapVisible = !isMapVisible;

        if (isMapVisible && Tour != null)
        {
            // Ждем долю секунды, чтобы Blazor отрендерил div перед тем как JS начнет в него рисовать карту
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("leafletBridge.createRoute", 
                $"map-{Tour.Id}", 
                Tour.StartLatitude, 
                Tour.StartLongitude, 
                Tour.Title);
        }
    }
@* } 
