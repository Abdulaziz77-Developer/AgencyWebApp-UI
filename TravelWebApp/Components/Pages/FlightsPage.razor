@page "/flights"
@using TravelWebApp.Components.Components_Ui
@inject IFlightService FlightService 
<Navbar />

<div class="bg-light min-vh-100">
    <!-- Page Header -->
    <div class="bg-white border-bottom">
        <div class="container py-5">
            <h1 class="display-5 fw-bold text-dark mb-2">Book Flights</h1>
            <p class="text-muted mb-0">Best deals on flights to top destinations</p>
        </div>
    </div>

    <div class="container py-5">
        <div class="row g-4">
            <!-- Sidebar Filters -->
            <div class="col-lg-3">
                <div class="card border rounded-4 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-4">
                            <h5 class="fw-semibold mb-0">Filters</h5>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">From</label>
                            <input type="text" class="form-control" placeholder="Origin">
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label small fw-bold">To</label>
                            <input type="text" class="form-control" placeholder="Destination">
                        </div>

                        <button class="btn btn-primary w-100">Search Flights</button>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-9">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="text-muted">Showing <span class="fw-semibold text-dark">@flights.Count</span> flights</div>
                </div>

                <div class="row g-4">
                    @foreach (var flight in flights)
                    {
                        <div class="col-12">
                            <CardFlight Flight="@flight" />
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Flight> flights = new();
    
    protected override async Task OnInitializedAsync() 
    {
        flights = await FlightService.GetFlightsAsync();
    }
}