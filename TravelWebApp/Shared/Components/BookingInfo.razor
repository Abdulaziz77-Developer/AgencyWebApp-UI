@namespace TravelWebApp.Shared.Components
@inject IBookingService BookingService 
@inject NavigationManager Navigation
<div class="card border rounded-4 mb-4">
    <div class="card-header bg-white border-bottom p-4">
        <div class="d-flex align-items-start justify-content-between">
            <div>
                <h4 class="fs-4 fw-bold mb-1">@Title</h4>
                <p class="small text-muted mb-0">Забронировано: @BookedDate</p>
            </div>
            <div class="d-flex align-items-center gap-2 px-3 py-1 rounded-pill @StatusBadgeClass">
                @if (IsPending)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock">
                        <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21.801 10A10 10 0 1 1 17 3.335"></path>
                        <path d="m9 11 3 3L22 4"></path>
                    </svg>
                }
                <span class="small fw-medium">@text</span>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <div class="row g-4 mb-4">
            <div class="col-md-4 d-flex align-items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted">
                    <path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path>
                </svg>
                <div>
                    <p class="small text-muted mb-0">Дата поездки</p>
                    <p class="fw-semibold mb-0">@TripDate</p>
                </div>
            </div>
            <div class="col-md-4 d-flex align-items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
                <div>
                    <p class="small text-muted mb-0">Количество гостей</p>
                    <p class="fw-semibold mb-0">@Guests</p>
                </div>
            </div>
            <div class="col-md-4 d-flex align-items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted">
                    <rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" x2="22" y1="10" y2="10"></line>
                </svg>
                <div>
                    <p class="small text-muted mb-0">Общая стоимость</p>
                    <p class="fw-semibold text-primary mb-0">@Price</p>
                </div>
            </div>
        </div>
        @if (Status)
        {
            
        }
        else
        {
            <div class="d-flex gap-2">
                <button class="btn btn-danger btn-sm px-3" @onclick="CancelBooking">Отменить бронирование</button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int BookingId { get; set; }
    [Parameter] public string Title { get; set; } = "Отпуск на Мальдивах";
    [Parameter] public string BookedDate { get; set; } = "2024-12-20";
    [Parameter] public bool Status { get; set; } 
    [Parameter] public string TripDate { get; set; } = "2025-02-14";
    [Parameter] public int Guests { get; set; } = 2;
    [Parameter] public string Price { get; set; } = "$2,500";
    private string text => Status ? "Подтверждено" : "В ожидании";
    private bool IsPending => Status;
    private string StatusBadgeClass => IsPending ? "bg-success bg-opacity-10 text-success" : "bg-warning bg-opacity-10 text-warning";

    public  async Task CancelBooking()
    {
        await BookingService.DeleteBookingAsync(BookingId);
        Navigation.NavigateTo("/");
    }
}