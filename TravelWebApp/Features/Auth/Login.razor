@page "/login"
<div class="min-vh-100 d-flex align-items-center justify-content-center"
     style="background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);">
    <div class="card border-0 shadow-lg rounded-4 w-100" style="max-width: 450px;">
        <div class="card-header bg-transparent border-0 pt-5 pb-4 text-center">
            <h2 class="fw-bold mb-1">С возвращением!</h2>
            <p class="text-muted mb-0">Войдите в свою учетную запись</p>
        </div>

        <div class="card-body px-5 pb-5">
            <form @onsubmit:preventDefault>

                @if (errorMessage != null)
                {
                    <div class="alert alert-danger small mb-3">
                        @errorMessage
                    </div>
                }

                <div class="mb-4">
              <label class="form-label small fw-bold">Электронная почта</label>
                    <input type="email"
                           class="form-control"
                           @bind="email"
                           required />
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold">Пароль</label>
                    <input type="password"
                           class="form-control"
                           @bind="password"
                           required />
                </div>

                <button type="button"
                        class="btn btn-primary w-100 py-2"
                        @onclick="HandleLogin"
                        disabled="@isLoading">
                    @(isLoading ? "Signing in..." : "Sign In")
                </button>

            </form>
        </div>
    </div>
</div>

