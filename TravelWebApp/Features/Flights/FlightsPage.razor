@page "/flights"
@using AgencyWebApp.Client.Infrastructure.Api.Dtos.Flights
@using TravelWebApp.Shared.Components
@inject IFlightService FlightService 
<Navbar />

<div class="bg-light min-vh-100">
    <!-- Page Header -->
    <div class="bg-white border-bottom">
        <div class="container py-5">
            <h1 class="display-5 fw-bold text-dark mb-2">Поиск рейсов</h1>
            <p class="text-muted mb-0">Лучшие предложения на рейсы в популярные направления</p>
        </div>
    </div>

    <div class="container py-5">
        <div class="row g-4">
            <!-- Sidebar Filters -->
            <div class="col-lg-3">
                <div class="card border rounded-4 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-4">
                            <h5 class="fw-semibold mb-0">Фильтры</h5>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Откуда</label>
                            <input type="text" class="form-control" placeholder="Источник">
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label small fw-bold">Куда</label>
                            <input type="text" class="form-control" placeholder="Назначение">
                        </div>

                        <button class="btn btn-primary w-100">Поиск рейсов</button>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-9">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="text-muted">Отображение <span class="fw-semibold text-dark">@flights.Count</span> рейсов</div>
                </div>

                <div class="row g-4">
                    @foreach (var flight in flights)
                    {
                        <div class="col-12">
                            <CardFlight Flight="@flight" />
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

