@code {
    private bool bookingSubmitted = false;
    private BookingRequest bookingModel = new BookingRequest();

    private string _bookingType = "Tour";
    private string bookingType
    {
        get => _bookingType;
        set { _bookingType = value; selectedEntityId = 0; bookingSubmitted = false; }
    }

    private int selectedEntityId = 0;

    private Tour? tour;
    private Hotel? hotel;
    private Flight? flight;

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        if (!string.IsNullOrEmpty(query["type"]))
            bookingType = query["type"]!;

        if (int.TryParse(query["id"], out int id))
            selectedEntityId = id;

        switch (bookingType)
        {
            case "Hotel": hotel = await HotelService.GetHotelByIdAsync(id); break;
            case "Tour": tour = await TourService.GetTourByIdAsync(id); break;
            case "Flight": flight = await FlightService.GetFlightByIdAsync(id); break;
        }
    }

    private async Task HandleBooking()
    {
        var customAuthProvider = (CustomAuthStateProvider)AuthStateProvider;
        var userId = customAuthProvider.GetUserId();

        if (userId == null)
        {
            var returnUrl = $"/booking?type={bookingType}&id={selectedEntityId}";
            Navigation.NavigateTo($"/login?ReturnUrl={Uri.EscapeDataString(returnUrl)}");
            return;
        }

        if (selectedEntityId == 0) return;

        var booking = new TravelWebApp.Models.Booking
        {
            UserId = userId.Value,
            BookingDate = DateTime.Now,
            Status = false,
            TotalPrice = 0
        };

        switch (bookingType)
        {
            case "Tour": booking.TourId = selectedEntityId; break;
            case "Hotel": booking.HotelId = selectedEntityId; break;
            case "Flight": booking.FlightId = selectedEntityId; break;
        }

        var success = await BookingService.CreateBookingAsync(booking);
        if (success)
        {
            bookingSubmitted = true;
            StateHasChanged();
            Navigation.NavigateTo("/");
        }
    }

    public class BookingRequest
    {
        public DateTime StartDate { get; set; } = DateTime.Today;
        public DateTime EndDate { get; set; } = DateTime.Today.AddDays(1);
        [Range(1, 20, ErrorMessage = "Please enter between 1 and 20 guests")]
        public int Guests { get; set; } = 1;
    }
} *@
@page "/booking"
@using Microsoft.AspNetCore.Components.Authorization
@using System.ComponentModel.DataAnnotations
@using TravelWebApp.Services.Interfaces
@using TravelWebApp.Models
@using TravelWebApp.Auth
@using TravelWebApp.Components.Components_Ui
@inject IBookingService BookingService
@inject IOtpService OtpService
@inject AuthenticationStateProvider AuthStateProvider
@inject ITourService TourService
@inject IHotelService HotelService
@inject IFlightService FlightService
@inject NavigationManager Navigation

<Navbar />

<div class="min-vh-100 bg-light d-flex align-items-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-7">

                <div class="text-center mb-4">
                    <h2 class="fw-bold">Оформление бронирования</h2>
                    <p class="text-muted">Проверьте детали вашего выбора перед подтверждением</p>
                </div>

                @* --- СЕКЦИЯ С КАРТОЧКОЙ ВЫБРАННОГО ОБЪЕКТА --- *@
                <div class="shadow-sm border rounded bg-white p-3">
                    @if (bookingType is "Hotel" && hotel != null)
                    {
                        <CardHotel Hotel="@hotel" />
                    }
                    else if (bookingType is "Tour" && tour != null)
                    {
                        <CardTour Tour="@tour" />
                    }
                    else if (bookingType is "Flight" && flight != null)
                    {
                        <CardFlight Flight="@flight" />
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Загрузка...</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-4 text-center">
                    @* Кнопка теперь запускает процесс OTP *@
                    <button class="btn btn-primary btn-lg px-5 shadow"
                            @onclick="StartOtpProcess"
                            disabled="@(selectedEntityId == 0 || isProcessing)">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Подтвердить и забронировать
                    </button>

                    <div class="mt-3">
                        <button class="btn btn-link text-decoration-none" @onclick='() => Navigation.NavigateTo("/")'>
                            Отмена
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@* --- МОДАЛЬНОЕ ОКНО ПОДТВЕРЖДЕНИЯ (OTP) --- *@
@if (showOtpModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(5px);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">Подтверждение Email</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showOtpModal = false"></button>
                </div>
                <div class="modal-body text-center p-4">
                    <div class="mb-3">
                        <i class="bi bi-shield-lock text-primary" style="font-size: 3rem;"></i>
                    </div>
                    <h5>Введите код подтверждения</h5>
                    <p class="text-muted">Мы отправили секретный код на вашу почту <br /> <strong>@userEmail</strong></p>

                    <div class="form-group mb-3 px-4">
                        <input type="text" class="form-control form-control-lg text-center fw-bold"
                               placeholder="000000"
                               maxlength="6"
                               @bind="enteredOtp"
                               style="letter-spacing: 8px; font-size: 1.5rem; border: 2px solid #0d6efd;" />
                    </div>

                    @if (!string.IsNullOrEmpty(otpError))
                    {
                        <div class="alert alert-danger py-2 small">@otpError</div>
                    }
                </div>
                <div class="modal-footer justify-content-center border-0 pb-4">
                    <button class="btn btn-light px-4 me-2" @onclick="() => showOtpModal = false">Отмена</button>
                    <button class="btn btn-primary px-4" @onclick="VerifyAndFinalize">Подтвердить</button>
                </div>
            </div>
        </div>
    </div>
}

<Footer />

@code {
    // Состояние OTP
    private bool showOtpModal = false;
    private bool isProcessing = false;
    private string enteredOtp = "";
    private string otpError = "";
    private string userEmail = "";

    // Твои существующие поля
    private bool bookingSubmitted = false;
    private int selectedEntityId = 0;
    private string _bookingType = "Tour";
    private string bookingType
    {
        get => _bookingType;
        set { _bookingType = value; selectedEntityId = 0; bookingSubmitted = false; }
    }

    private Tour? tour;
    private Hotel? hotel;
    private Flight? flight;

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        if (!string.IsNullOrEmpty(query["type"]))
            bookingType = query["type"]!;

        if (int.TryParse(query["id"], out int id))
            selectedEntityId = id;

        switch (bookingType)
        {
            case "Hotel": hotel = await HotelService.GetHotelByIdAsync(id); break;
            case "Tour": tour = await TourService.GetTourByIdAsync(id); break;
            case "Flight": flight = await FlightService.GetFlightByIdAsync(id); break;
        }
    }

    // ШАГ 1: Отправка кода при нажатии на основную кнопку
    private async Task StartOtpProcess()
    {
        isProcessing = true;
        otpError = "";

        var customAuthProvider = (CustomAuthStateProvider)AuthStateProvider;
        userEmail = await customAuthProvider.GetUserEmail(); // Убедись, что метод возвращает почту из токена

        if (string.IsNullOrEmpty(userEmail))
        {
            var returnUrl = $"/booking?type={bookingType}&id={selectedEntityId}";
            Navigation.NavigateTo($"/login?ReturnUrl={Uri.EscapeDataString(returnUrl)}");
            return;
        }

        var sent = await OtpService.SendOtpAsync(userEmail);
        if (sent)
        {
            showOtpModal = true;
        }
        else
        {
            otpError = "Не удалось отправить код. Попробуйте еще раз.";
        }
        isProcessing = false;
    }

    // ШАГ 2: Проверка кода из модального окна
    private async Task VerifyAndFinalize()
    {
        if (string.IsNullOrWhiteSpace(enteredOtp) || enteredOtp.Length < 6)
        {
            otpError = "Введите полный 6-значный код";
            return;
        }

        var isVerified = await OtpService.VerifyOtpAsync(userEmail, enteredOtp);
        if (isVerified)
        {
            await HandleBooking(); // Если код верный, сохраняем в базу
            showOtpModal = false;
        }
        else
        {
            otpError = "Неверный код. Пожалуйста, проверьте почту.";
        }
    }

    // ШАГ 3: Финальное сохранение в базу данных
    private async Task HandleBooking()
    {
        var customAuthProvider = (CustomAuthStateProvider)AuthStateProvider;
        var userId = customAuthProvider.GetUserId();

        if (userId == null || selectedEntityId == 0) return;

        var booking = new TravelWebApp.Models.Booking
        {
            UserId = userId.Value,
            BookingDate = DateTime.Now,
            Status = true, // Теперь ставим True, так как пройдена проверка Email
            TotalPrice = 0
        };

        switch (bookingType)
        {
            case "Tour": booking.TourId = selectedEntityId; break;
            case "Hotel": booking.HotelId = selectedEntityId; break;
            case "Flight": booking.FlightId = selectedEntityId; break;
        }

        var success = await BookingService.CreateBookingAsync(booking);
        if (success)
        {
            bookingSubmitted = true;
            Navigation.NavigateTo("/");
        }
    }

    public class BookingRequest
    {
        public DateTime StartDate { get; set; } = DateTime.Today;
        public DateTime EndDate { get; set; } = DateTime.Today.AddDays(1);
        [Range(1, 20, ErrorMessage = "Please enter between 1 and 20 guests")]
        public int Guests { get; set; } = 1;
    }
}