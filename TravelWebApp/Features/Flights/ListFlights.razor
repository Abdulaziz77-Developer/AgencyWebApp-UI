@using AgencyWebApp.Client.Infrastructure.Api.Dtos.Flights
@using TravelWebApp.Shared.Components
@inject IFlightService FlightService

@if(string.IsNullOrWhiteSpace(SearchTerm))
{
    <div class="container py-5">
        <div class="row mb-5">
            <div class="col-12 text-center">
                <h2 class="display-6 fw-bold">Популярные рейсы</h2>
                <p class="text-muted">Лучшие предложения на рейсы в популярные направления</p>
            </div>
        </div>

        <div class="row g-4">
            @foreach (var flight in flights)
            {
                <div class="col-lg-6">
                    <CardFlight Flight="@flight" />
                </div>
            }
        </div>
    </div>
}
@if(@Date is  not null )
{
     foreach (var item in flights.Where(date => date.arrivalTime == Date || date.departureTime == Date))
    {
        <div class="col-lg-6">
            <CardFlight Flight="item"/>
        </div>
    }
}
else
{
    <div class="row mt-4">
        @foreach (var flight in flights.Where(f => string.IsNullOrEmpty(SearchTerm)
            || f.fromCity.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
            || f.toCity.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)))
    {
        <div class="col-lg-6">
            <CardFlight Flight="flight" />
        </div>
        }
    </div>
}


