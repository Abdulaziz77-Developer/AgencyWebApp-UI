@namespace TravelWebApp.Components.Components_Ui
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime


<style>
    .card-hover-effect {
        transition: box-shadow 0.3s ease, transform 0.3s ease;
        cursor: pointer;
    }

        .card-hover-effect:hover {
            box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
        }
    /* Стиль для кнопки карты поверх фото */
    .map-trigger-btn {
        transition: transform 0.2s ease;
    }

        .map-trigger-btn:hover {
            transform: scale(1.1);
            background-color: #f8f9fa !important;
        }
</style>

<div class="card h-100 border rounded-4 overflow-hidden shadow-sm card-hover-effect">
    <div class="position-relative" style="height: 12rem;">
        <img src="@Hotel?.PhotoUrl" alt="@Hotel?.Name" class="w-100 h-100 object-fit-cover">

        @* Кнопка геолокации на фото (как в CardTour) *@
        <button @onclick="OpenMap" class="position-absolute bottom-0 end-0 btn btn-white bg-white m-3 shadow-sm rounded-circle p-2 map-trigger-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d6efd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3" /></svg>
        </button>

        <div class="position-absolute top-0 start-0 m-3">
            <div class="d-flex gap-1">
                @for (int i = 0; i < 5; i++)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning">
                        <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
                    </svg>
                }
            </div>
        </div>
    </div>

    <div class="card-body p-3 pb-2">
        @* Иконка и текст города теперь кликабельны для открытия карты *@
        <div class="d-flex align-items-center gap-2 small text-muted mb-2" @onclick="OpenMap" style="cursor:pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin text-primary">
                <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
                <circle cx="12" cy="10" r="3"></circle>
            </svg>
            @Hotel?.City
        </div>
        <h5 class="card-title fw-semibold mb-2">@Hotel?.Name</h5>
        <p class="card-text small text-muted mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
            @Hotel?.Description
        </p>
        <div class="d-flex align-items-center gap-1 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning">
                <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
            </svg>
            <span class="small fw-medium">@Hotel?.Rating</span>
            <span class="small text-muted">Excellent</span>
        </div>
    </div>
    <div class="card-footer bg-white border-top-0 p-3 pt-0 d-flex align-items-center justify-content-between">
        <div>
            <span class="fs-4 fw-bold text-primary">$@Hotel?.Price</span>
            <span class="small text-muted"> /night</span>
        </div>
        <button class="btn btn-primary btn-sm px-3" @onclick="GoToBookingPage" @onclick:stopPropagation="true">Book Now</button>
    </div>
</div>

@* Компактное модальное окно с картой *@
@if (isMapVisible)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 9999;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm" style="max-width: 400px;">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header py-2">
                    <h6 class="modal-title fw-bold">Локация: @Hotel?.City</h6>
                    <button type="button" class="btn-close" @onclick="CloseMap"></button>
                </div>
                <div class="modal-body p-0">
                    @* Динамический ID для карты, чтобы не было конфликтов в списке *@
                    <div id="hotel-map-@Hotel?.Id" style="height: 300px; width: 100%; background: #eee;"></div>
                </div>
                <div class="modal-footer py-1">
                    <button class="btn btn-sm btn-secondary" @onclick="CloseMap">Закрыть</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Hotel? Hotel { get; set; }
    private bool isMapVisible = false;

    private async Task OpenMap()
    {
        isMapVisible = true;
        StateHasChanged(); // Обновляем UI, чтобы появился div для карты

        if (Hotel != null)
        {
            // Небольшая задержка, чтобы DOM успел отрисовать модалку
            await Task.Delay(400);

            // ПЕРЕДАЕМ КООРДИНАТЫ В ВАШ ФАЙЛ JAVASCRIPT
            await JSRuntime.InvokeVoidAsync("leafletBridge.showLocation",
                $"hotel-map-{Hotel.Id}",
                Hotel.Latitude,
                Hotel.Longitude,
                Hotel.Name);
        }
    }

    private void CloseMap() => isMapVisible = false;

    public void GoToBookingPage()
    {
        Navigation.NavigateTo($"/booking");
    }
}