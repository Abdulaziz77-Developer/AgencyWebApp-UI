@page "/"
@using TravelWebApp.Components.Components_Ui

<PageTitle>Home</PageTitle>

<Navbar />

<div class="hero-container">
    <h1 class="display-4 mt-4">Добро пожаловать в AgencyWeb</h1>
    <p class="fs-4">Откройте для себя потрясающие направления и создайте незабываемые воспоминания.</p>

    <div class="bg-white p-4 shadow mt-4 text-dark" style="border-radius: 20px;">
        <form class="row g-3">
            <div class="col-md-8">
                <label class="form-label fw-bold">Куда?</label>
                <input type="text" class="form-control" placeholder="Search places"
                @bind-value="searchTerm" @bind-value:event="oninput">
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Дата</label>
                <input type="date" class="form-control" @bind="searchDate">
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-dark w-100" @onclick="HandleSearch">Search</button>
            </div>
        </form>
    </div>
</div>

<ListTours SearchTerm="@searchTerm" />
<ListHotels SearchTerm="@searchTerm" />
<ListFlights SearchTerm="@searchTerm" Date="searchDate" />
<Footer />

<style>
    .hero-container {
        /* Flexbox centering as requested */
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        min-height: 100vh;
        margin: -1.5rem;
        padding-left: 3rem;

        /* Background: Blue overlay + Nature Image from Internet */
        background: linear-gradient(rgba(0, 0, 255, 0.4), rgba(0, 0, 255, 0.4)),
                    url('https://images.unsplash.com/photo-1472214103451-9374bd1c798e?q=80&w=2070&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        
        color: white;
    }
</style>
@code {
    private string searchTerm = "";
    private DateTime? searchDate;

    // Этот метод сработает при нажатии на кнопку Search
    private void HandleSearch()
    {
        // В Blazor изменение переменной searchTerm автоматически
        // приведет к обновлению дочерних компонентов, если они ее используют
        StateHasChanged();
    }
}